# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only — never reference this in a client component or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (resend.com) — outbound email + inbound parse webhook
RESEND_API_KEY=
# Signing secret for the inbound webhook (Resend dashboard > Webhooks). Used to verify
# app/api/email/inbound requests actually came from Resend before we trust the payload.
RESEND_WEBHOOK_SECRET=
# The support address inbound email is routed to, e.g. support@yourdomain.com. Configure the
# matching MX/webhook DNS records early — they propagate slowly (see README DNS note).
INBOUND_EMAIL_ADDRESS=

# Gemini (aistudio.google.com) — conversation summaries + AI reply drafts
GEMINI_API_KEY=

# Base URL this app is deployed at, used to build the widget loader src and email links.
# Local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# SMTP Configuration (e.g. Gmail) for outbound emails
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
